<% layout("/layouts/boilerplate") -%>

<div class="row justify-content-center">
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm text-center">
      <div class="card-body p-5">
        <div class="mb-3 text-danger fs-1">
          <i class="bi bi-exclamation-triangle-fill"></i>
        </div>
        <h1 class="h3 fw-bold mb-3">Something went wrong</h1>
        <p class="text-danger fw-semibold mb-2"><%= message %></p>
        <p class="text-muted mb-4">Please try again, go back, or return to the home page.</p>
        <div class="d-flex justify-content-center flex-wrap gap-3">
          <a href="javascript:history.back()" class="btn btn-outline-secondary">Go Back</a>
          <a href="/" class="btn btn-primary">Home</a>
        </div>
      </div>
    </div>
  </div>
</div>
