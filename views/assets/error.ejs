<% layout("/layouts/boilerplate") -%>

<section class="error-wrap">
  <div class="error-shell text-center">
    <span class="eyebrow mb-3"><i class="bi bi-exclamation-octagon"></i> Something went wrong</span>
    <h2 class="headline-gradient mb-3">An error interrupted this experience.</h2>
    <p class="text-danger fw-semibold mb-3"><%= message %></p>
    <p class="muted-copy mb-4">Please try again, go back, or return to the homepage to continue exploring the platform.</p>
    <div class="d-flex justify-content-center gap-3 flex-wrap">
      <a href="javascript:history.back()" class="btn btn-outline-secondary">Go Back</a>
      <a href="/" class="btn btn-primary">Home</a>
    </div>
  </div>
</section>
