<% layout("/layouts/boilerplate") -%>

<body>
<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <div class="card shadow p-4">
        <h2 class="mb-4 text-center">Add New Listing</h2>

        <form method="post" action="/listings" class="needs-validation" novalidate>

          <!-- Title -->
          <div class="mb-3">
            <label class="form-label">Title</label>
            <input 
              type="text" 
              class="form-control" 
              name="listing[title]"
              placeholder="Enter title" 
              required>
            <div class="invalid-feedback">Please choose a title.</div>
          </div>

          <!-- Description -->
          <div class="mb-3">
            <label class="form-label">Description</label>
            <input 
              type="text" 
              class="form-control" 
              name="listing[description]"
              placeholder="Enter description" 
              required>
            <div class="invalid-feedback">Please choose a description.</div>
          </div>

          <!-- Image -->
          <div class="mb-3">
            <label class="form-label">Image URL</label>
            <input 
              type="text" 
              class="form-control" 
              name="listing[image][url]"
              placeholder="Enter image link (optional)">
          </div>

          <!-- Price -->
          <div class="mb-3">
            <label class="form-label">Price</label>
            <input 
              type="number" 
              class="form-control" 
              name="listing[price]"
              placeholder="Enter price" 
              required>
            <div class="invalid-feedback">Please enter a valid price.</div>
          </div>

          <!-- Location -->
          <div class="mb-3">
            <label class="form-label">Location</label>
            <input 
              type="text" 
              class="form-control" 
              name="listing[location]"
              placeholder="Enter location" 
              required>
            <div class="invalid-feedback">Please enter location.</div>
          </div>

          <!-- Country -->
          <div class="mb-3">
            <label class="form-label">Country</label>
            <input 
              type="text" 
              class="form-control" 
              name="listing[country]"
              placeholder="Enter country" 
              required>
            <div class="invalid-feedback">Please enter country.</div>
          </div>

          <!-- Terms -->
          <div class="form-check mb-3">
            <input class="form-check-input" type="checkbox" required>
            <label class="form-check-label">
              Agree to terms and conditions
            </label>
            <div class="invalid-feedback">
              You must agree before submitting.
            </div>
          </div>

          <!-- Submit -->
          <div class="d-grid">
            <button type="submit" class="btn btn-success">
              Add Listing
            </button>
          </div>

        </form>
      </div>
    </div>
  </div>
</div>
</body>