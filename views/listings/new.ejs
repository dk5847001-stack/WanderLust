<% layout("/layouts/boilerplate") -%>

<section class="form-wrap">
  <div class="form-shell">
    <div class="section-heading">
      <div>
        <span class="eyebrow mb-3"><i class="bi bi-plus-circle"></i> Publish a listing</span>
        <h1 class="page-title headline-gradient">Add a new stay to the WanderLust universe.</h1>
        <p class="page-subtitle mb-0">Create a polished listing with imagery, pricing, destination details, and category context.</p>
      </div>
    </div>

    <form method="post" action="/listings" class="needs-validation" novalidate enctype="multipart/form-data">
      <div class="row g-4">
        <div class="col-12">
          <label class="form-label fw-semibold">Title</label>
          <input type="text" class="form-control" name="listing[title]" placeholder="Skyline penthouse, forest dome, beach villa" required>
          <div class="invalid-feedback">Please choose a title.</div>
        </div>

        <div class="col-12">
          <label class="form-label fw-semibold">Description</label>
          <textarea class="form-control" name="listing[description]" rows="4" placeholder="Describe the vibe, highlights, and guest experience" required></textarea>
          <div class="invalid-feedback">Please choose a description.</div>
        </div>

        <div class="col-md-6">
          <label class="form-label fw-semibold">Upload image</label>
          <input type="file" class="form-control" name="listing[image][url]">
        </div>

        <div class="col-md-6">
          <label class="form-label fw-semibold">Price per night</label>
          <input type="number" class="form-control" name="listing[price]" placeholder="7500" required>
          <div class="invalid-feedback">Please enter a valid price.</div>
        </div>

        <div class="col-md-6">
          <label class="form-label fw-semibold">Location</label>
          <input type="text" class="form-control" name="listing[location]" placeholder="Manali, Goa, Jaipur" required>
          <div class="invalid-feedback">Please enter location.</div>
        </div>

        <div class="col-md-6">
          <label class="form-label fw-semibold">Country</label>
          <input type="text" class="form-control" name="listing[country]" placeholder="India" required>
          <div class="invalid-feedback">Please enter country.</div>
        </div>

        <div class="col-12">
          <div class="form-check">
            <input class="form-check-input" type="checkbox" required>
            <label class="form-check-label">I confirm the listing details are accurate and ready to publish.</label>
            <div class="invalid-feedback">You must agree before submitting.</div>
          </div>
        </div>

        <div class="col-12 d-flex flex-wrap gap-3">
          <button type="submit" class="btn btn-primary">Publish Listing</button>
          <a href="/listings" class="btn btn-outline-secondary">Back to Listings</a>
        </div>
      </div>
    </form>
  </div>
</section>
