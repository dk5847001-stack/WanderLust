<% layout("/layouts/boilerplate") -%>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-4 p-md-5">
        <div class="mb-4">
          <h1 class="h3 fw-bold mb-1">Add New Listing</h1>
          <p class="text-muted mb-0">Create a listing with title, image, price, and destination details.</p>
        </div>

        <form method="post" action="/listings" class="needs-validation" novalidate enctype="multipart/form-data">
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label fw-semibold">Title</label>
              <input type="text" class="form-control" name="listing[title]" placeholder="Enter listing title" required>
              <div class="invalid-feedback">Please choose a title.</div>
            </div>

            <div class="col-12">
              <label class="form-label fw-semibold">Description</label>
              <textarea class="form-control" name="listing[description]" rows="4" placeholder="Enter description" required></textarea>
              <div class="invalid-feedback">Please choose a description.</div>
            </div>

            <div class="col-md-6">
              <label class="form-label fw-semibold">Upload Image</label>
              <input type="file" class="form-control" name="listing[image][url]">
            </div>

            <div class="col-md-6">
              <label class="form-label fw-semibold">Price</label>
              <input type="number" class="form-control" name="listing[price]" placeholder="Enter price" required>
              <div class="invalid-feedback">Please enter a valid price.</div>
            </div>

            <div class="col-md-6">
              <label class="form-label fw-semibold">Location</label>
              <input type="text" class="form-control" name="listing[location]" placeholder="Enter location" required>
              <div class="invalid-feedback">Please enter location.</div>
            </div>

            <div class="col-md-6">
              <label class="form-label fw-semibold">Country</label>
              <input type="text" class="form-control" name="listing[country]" placeholder="Enter country" required>
              <div class="invalid-feedback">Please enter country.</div>
            </div>

            <div class="col-12">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" required>
                <label class="form-check-label">I confirm the listing details are correct.</label>
                <div class="invalid-feedback">You must agree before submitting.</div>
              </div>
            </div>

            <div class="col-12 d-flex flex-wrap gap-3">
              <button type="submit" class="btn btn-primary">Publish Listing</button>
              <a href="/listings" class="btn btn-outline-secondary">Back to Listings</a>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
