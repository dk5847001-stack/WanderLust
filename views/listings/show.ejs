<% layout("/layouts/boilerplate") -%>

<section class="page-stack">
  <section class="hero-card">
    <div class="section-heading">
      <div>
        <span class="eyebrow mb-3">
          <i class="bi bi-geo-alt-fill"></i>
          Listing spotlight
        </span>
        <h1 class="page-title headline-gradient"><%= listing.title %></h1>
        <p class="page-subtitle mb-0"><%= listing.location %>, <%= listing.country %></p>
      </div>
      <div class="d-flex flex-wrap gap-2">
        <button type="button" class="owner-btn btn btn-outline-secondary owner-badge"
          data-bs-toggle="popover" data-bs-placement="left"
          data-bs-title="<%= listing.owner?.username || 'Unknown host' %>"
          data-bs-content="<%= listing.owner?.email || 'No email available' %>">
          <i class="bi bi-person-badge"></i>
          Hosted by <%= listing.owner?.username || "Unknown" %>
        </button>
        <span class="category-pill"><i class="bi bi-tag"></i> <%= listing.category || "Featured" %></span>
      </div>
    </div>

    <% if(currUser && listing.owner && currUser._id.equals(listing.owner._id)){ %>
      <div class="d-flex flex-wrap gap-2 mb-4">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-primary">Edit Listing</a>
        <form method="post" action="/listings/<%= listing._id %>?_method=DELETE" onsubmit="return confirm('Are you sure?');">
          <button class="btn btn-outline-danger" type="submit">Delete Listing</button>
        </form>
      </div>
    <% } %>

    <div class="detail-grid">
      <div class="detail-image">
        <img src="<%= listing.image?.url || '/default.jpg' %>" alt="<%= listing.title %>">
      </div>

      <aside class="detail-card">
        <div class="meta-row mb-3">
          <span class="stat-pill"><i class="bi bi-currency-rupee"></i> &#8377; <%= listing.price.toLocaleString('en-IN') %> / night</span>
          <span class="stat-pill"><i class="bi bi-star-half"></i> <%= avgRating ? avgRating.toFixed(1) : "No rating yet" %></span>
        </div>

        <h4 class="fw-semibold mb-3">About this stay</h4>
        <p class="muted-copy mb-4"><%= listing.description %></p>

        <div class="content-grid">
          <div class="metric-card">
            <span class="mini-label">Location</span>
            <h5 class="mb-1"><%= listing.location %></h5>
            <p class="muted-copy mb-0"><%= listing.country %></p>
          </div>
          <div class="metric-card">
            <span class="mini-label">Reviews</span>
            <h5 class="mb-1"><%= listing.reviews.length %> insights</h5>
            <p class="muted-copy mb-0">Guest feedback builds trust and discovery quality.</p>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="content-grid" style="gap: 1.5rem;">
    <div class="review-form form-shell">
      <div class="section-heading">
        <div>
          <span class="mini-label">Guest feedback</span>
          <h3>Reviews and ratings</h3>
        </div>
        <span class="stat-pill">Average: <strong><%= avgRating ? avgRating.toFixed(1) : "No rating" %></strong></span>
      </div>

      <% if(currUser && (!listing.owner || !currUser._id.equals(listing.owner._id))){ %>
        <form action="/listings/<%= listing._id %>/reviews" method="post" class="needs-validation" novalidate>
          <div class="mb-3">
            <label class="form-label fw-semibold">Rating</label>
            <fieldset class="starability-slot">
              <input type="radio" name="review[rating]" value="1" checked>
              <input type="radio" name="review[rating]" value="2">
              <input type="radio" name="review[rating]" value="3">
              <input type="radio" name="review[rating]" value="4">
              <input type="radio" name="review[rating]" value="5">
            </fieldset>
          </div>

          <div class="mb-3">
            <textarea name="review[comment]" class="form-control" rows="4" required minlength="10"
              placeholder="Share what made this stay memorable"></textarea>
          </div>

          <button class="btn btn-primary" type="submit">Submit Review</button>
        </form>
      <% } else if(currUser){ %>
        <p class="muted-copy mb-0">You cannot review your own listing.</p>
      <% } else { %>
        <p class="muted-copy mb-0">Please login to write a review.</p>
      <% } %>
    </div>

    <div class="review-list">
      <% if(listing.reviews.length > 0){ %>
        <% listing.reviews.forEach(review => { %>
          <article class="review-card">
            <div class="d-flex justify-content-between align-items-start gap-3 mb-3 flex-wrap">
              <div>
                <h5 class="mb-1"><%= review.author?.username || "Anonymous" %></h5>
                <p class="muted-copy mb-0">Community review</p>
              </div>
              <p class="starability-result mb-0" data-rating="<%= review.rating %>"></p>
            </div>

            <p class="mb-3"><%= review.comment %></p>

            <% if(currUser && review.author && review.author._id.equals(currUser._id)){ %>
              <form method="post" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                <button class="btn btn-outline-danger btn-sm" type="submit">Delete Review</button>
              </form>
            <% } %>
          </article>
        <% }) %>
      <% } else { %>
        <div class="empty-state glass-panel" style="grid-column: 1 / -1;">
          <i class="bi bi-chat-square-heart"></i>
          <h4 class="mt-3">No reviews yet</h4>
          <p class="muted-copy mb-0">Be the first guest to share an experience for this listing.</p>
        </div>
      <% } %>
    </div>
  </section>

  <section class="map-shell position-relative">
    <div class="section-heading">
      <div>
        <span class="mini-label">Map view</span>
        <h3>See where this stay is located</h3>
      </div>
    </div>

    <div class="map-frame position-relative">
      <div class="map-loader" id="mapLoader">Loading map...</div>
      <div id="map" style="height:100%;"></div>
    </div>
  </section>
</section>

<script>
document.addEventListener("DOMContentLoaded", () => {
  loadMap();
});

const apiKey = "FmtEvoD5gfMXGun2J9YQ";

async function loadMap() {
  try {
    const place = "<%= listing.location %>, <%= listing.country %>";
    const res = await fetch(`https://api.maptiler.com/geocoding/${encodeURIComponent(place)}.json?key=${apiKey}`);
    const data = await res.json();

    if (!data.features.length) {
      document.getElementById("mapLoader").innerText = "Map not available";
      return;
    }

    const coords = data.features[0].center;

    const map = new maplibregl.Map({
      container: "map",
      style: `https://api.maptiler.com/maps/streets/style.json?key=${apiKey}`,
      center: coords,
      zoom: 12
    });

    map.addControl(new maplibregl.NavigationControl(), "top-right");

    const popup = new maplibregl.Popup({ offset: 25 }).setHTML(`
      <div style="font-size:14px">
        <strong><%= listing.title %></strong><br>
        <span><%= listing.location %>, <%= listing.country %></span>
      </div>
    `);

    new maplibregl.Marker({ color: "#35d0ff" })
      .setLngLat(coords)
      .setPopup(popup)
      .addTo(map);

    map.flyTo({
      center: coords,
      zoom: 12,
      speed: 1.1
    });

    document.getElementById("mapLoader").style.display = "none";
  } catch (err) {
    document.getElementById("mapLoader").innerText = "Map failed to load";
    console.log("Map error:", err);
  }
}
</script>
