<% layout("/layouts/boilerplate") -%>

<body class="bg-light">

<div class="show container py-5">

  <!-- Title + Location -->
  <div class="mb-3">
    <h2 class="dk fw-bold"><%= listings.title %></h2>
    <p class="dk text-muted mb-0">
      📍 <%= listings.location %>, <%= listings.country %>
    </p>
  </div>

  <!-- Image + Side Card -->
  <div class="row g-4">

    <!-- Main Image -->
    <div class="col-lg-8">
      <div class="position-relative rounded-4 overflow-hidden shadow-sm">
        <img 
          src="<%= listings.image.url %>" 
          class="w-100"
          style="height: 400px; object-fit: cover;"
        >

        <!-- Wishlist -->
        <button class="btn btn-light rounded-circle position-absolute top-0 end-0 m-3 shadow wishlist-btn">
          <i class="fa-regular fa-heart"></i>
        </button>
      </div>

      <!-- Description -->
      <div class="mt-4">
        <h5 class="fw-semibold">About this place</h5>
        <p class="text-muted">
          <%= listings.description %>
        </p>
      </div>
    </div>

    <!-- Booking Card -->
    <div class="col-lg-4">
      <div class="card border-0 shadow rounded-4 p-4 sticky-top" style="top: 100px;">
        
        <h4 class="fw-bold mb-3">
          &#8377; <%= listings.price.toLocaleString("en-IN") %>
          <span class="fs-6 text-muted">/ night</span>
        </h4>

        <!-- Fake booking UI -->
        <div class="mb-3">
          <label class="form-label small">Check-in</label>
          <input type="date" class="form-control">
        </div>

        <div class="mb-3">
          <label class="form-label small">Check-out</label>
          <input type="date" class="form-control">
        </div>

        <div class="mb-3">
          <label class="form-label small">Guests</label>
          <input type="number" class="form-control" placeholder="1 guest">
        </div>

        <button class="btn btn-danger w-100 rounded-pill fw-semibold mb-2">
          Reserve
        </button>

        <small class="text-muted text-center d-block">
          You won't be charged yet
        </small>

      </div>
    </div>

  </div>

  <!-- Actions -->
  <div class="mt-4 d-flex gap-3">
    <a href="/listings/<%= listings._id %>/edit" 
       class="btn btn-outline-primary rounded-pill px-4">
      ✏️ Edit
    </a>

    <form method="post" action="/listings/<%= listings._id %>?_method=DELETE">
      <button type="submit" class="btn btn-outline-danger rounded-pill px-4">
        🗑 Delete
      </button>
    </form>
  </div>

</div>

</body>
