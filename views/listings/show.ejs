<% layout("/layouts/boilerplate") -%>

<body>
    <div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow">
                <div class="card-body">
                    <h1 class="card-title text-center mb-4">Listing Details</h1>

                    <ul class="list-group list-group-flush mb-4">
                        <li class="list-group-item">
                            <strong>Title:</strong> <%= listings.title %>
                        </li>
                        <li class="list-group-item">
                            <strong>Description:</strong> <%= listings.description %>
                        </li>
                        <li class="list-group-item">
                            <strong>Price:</strong> &#8377;<%= listings.price.toLocaleString("en-IN") %>
                        </li>
                        <li class="list-group-item">
                            <strong>Location:</strong> <%= listings.location %>
                        </li>
                        <li class="list-group-item">
                            <strong>Country:</strong> <%= listings.country %>
                        </li>
                    </ul>

                    <div class="d-flex gap-2">
                        <a href="/listings/<%= listings._id %>/edit" class="btn btn-warning">
                            Edit Listing
                        </a>

                        <form method="post" action="/listings/<%= listings._id %>?_method=DELETE">
                            <button type="submit" class="btn btn-danger">
                                Delete Listing
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
