<% layout("/layouts/boilerplate") -%>

<section class="mb-4">
  <div class="card border-0 shadow-sm">
    <div class="card-body p-4">
      <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
          <span class="badge text-bg-primary mb-2">Listing Details</span>
          <h1 class="h2 fw-bold mb-1"><%= listing.title %></h1>
          <p class="text-muted mb-0"><i class="bi bi-geo-alt me-1"></i><%= listing.location %>, <%= listing.country %></p>
        </div>

        <div class="d-flex flex-wrap gap-2">
          <button type="button" class="btn btn-outline-secondary"
            data-bs-toggle="popover" data-bs-placement="left"
            data-bs-title="<%= listing.owner?.username || 'Unknown host' %>"
            data-bs-content="<%= listing.owner?.email || 'No email available' %>">
            Host: <%= listing.owner?.username || "Unknown" %>
          </button>
          <span class="badge text-bg-light border text-dark px-3 py-2"><%= listing.category || "Featured" %></span>
        </div>
      </div>

      <% if(currUser && listing.owner && currUser._id.equals(listing.owner._id)){ %>
        <div class="d-flex flex-wrap gap-2 mb-4">
          <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-primary">Edit Listing</a>
          <form method="post" action="/listings/<%= listing._id %>?_method=DELETE" onsubmit="return confirm('Are you sure?');">
            <button class="btn btn-outline-danger" type="submit">Delete Listing</button>
          </form>
        </div>
      <% } %>

      <div class="row g-4 align-items-start">
        <div class="col-lg-8">
          <img src="<%= listing.image?.url || 'https://via.placeholder.com/1200x700?text=WanderLust+Listing' %>"
            alt="<%= listing.title %>" class="img-fluid rounded shadow-sm w-100" style="max-height: 500px; object-fit: cover;">
        </div>

        <div class="col-lg-4">
          <div class="card bg-light border-0 h-100">
            <div class="card-body">
              <h3 class="h4 text-success fw-bold mb-3">&#8377; <%= listing.price.toLocaleString('en-IN') %> / night</h3>
              <p class="mb-3"><%= listing.description %></p>
              <ul class="list-group list-group-flush">
                <li class="list-group-item bg-light px-0">
                  <strong>Average rating:</strong> <%= avgRating ? avgRating.toFixed(1) : "No rating yet" %>
                </li>
                <li class="list-group-item bg-light px-0">
                  <strong>Total reviews:</strong> <%= listing.reviews.length %>
                </li>
                <li class="list-group-item bg-light px-0">
                  <strong>Country:</strong> <%= listing.country %>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="mb-4">
  <div class="card border-0 shadow-sm">
    <div class="card-body p-4">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div>
          <h2 class="h4 mb-1">Reviews</h2>
          <p class="text-muted mb-0">Average: <strong><%= avgRating ? avgRating.toFixed(1) : "No rating" %></strong></p>
        </div>
      </div>

      <% if(currUser && (!listing.owner || !currUser._id.equals(listing.owner._id))){ %>
        <form action="/listings/<%= listing._id %>/reviews" method="post" class="needs-validation mb-4" novalidate>
          <div class="row g-3">
            <div class="col-md-4">
              <label class="form-label fw-semibold">Rating</label>
              <select class="form-select" name="review[rating]" required>
                <option value="5">5 - Excellent</option>
                <option value="4">4 - Very Good</option>
                <option value="3">3 - Good</option>
                <option value="2">2 - Fair</option>
                <option value="1">1 - Poor</option>
              </select>
            </div>
            <div class="col-12">
              <label class="form-label fw-semibold">Comment</label>
              <textarea name="review[comment]" class="form-control" rows="4" required minlength="10"
                placeholder="Write your review..."></textarea>
            </div>
            <div class="col-12">
              <button class="btn btn-primary" type="submit">Submit Review</button>
            </div>
          </div>
        </form>
      <% } else if(currUser){ %>
        <p class="text-muted">You cannot review your own listing.</p>
      <% } else { %>
        <p class="text-muted">Please login to write a review.</p>
      <% } %>

      <div class="row g-4">
        <% if(listing.reviews.length > 0){ %>
          <% listing.reviews.forEach(review => { %>
            <div class="col-md-6">
              <div class="card h-100">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-2">
                    <div>
                      <h5 class="card-title mb-1"><%= review.author?.username || "Anonymous" %></h5>
                      <small class="text-muted">Community review</small>
                    </div>
                    <span class="badge text-bg-warning">Rating: <%= review.rating %>/5</span>
                  </div>

                  <p class="card-text mb-3"><%= review.comment %></p>

                  <% if(currUser && review.author && review.author._id.equals(currUser._id)){ %>
                    <form method="post" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                      <button class="btn btn-outline-danger btn-sm" type="submit">Delete Review</button>
                    </form>
                  <% } %>
                </div>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="col-12">
            <div class="alert alert-secondary mb-0">No reviews yet.</div>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>

<section>
  <div class="card border-0 shadow-sm">
    <div class="card-body p-4">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div>
          <h2 class="h4 mb-1">Location Map</h2>
          <p class="text-muted mb-0">Map view for this stay.</p>
        </div>
      </div>

      <div class="position-relative">
        <div class="position-absolute top-50 start-50 translate-middle bg-white border rounded px-3 py-2 shadow-sm z-1" id="mapLoader">
          Loading map...
        </div>
        <div id="map" class="rounded-3 border" style="height: 400px;"></div>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", () => {
  loadMap();
});

const apiKey = "FmtEvoD5gfMXGun2J9YQ";

async function loadMap() {
  try {
    const place = "<%= listing.location %>, <%= listing.country %>";
    const res = await fetch(`https://api.maptiler.com/geocoding/${encodeURIComponent(place)}.json?key=${apiKey}`);
    const data = await res.json();

    if (!data.features.length) {
      document.getElementById("mapLoader").innerText = "Map not available";
      return;
    }

    const coords = data.features[0].center;

    const map = new maplibregl.Map({
      container: "map",
      style: `https://api.maptiler.com/maps/streets/style.json?key=${apiKey}`,
      center: coords,
      zoom: 12
    });

    map.addControl(new maplibregl.NavigationControl(), "top-right");

    const popup = new maplibregl.Popup({ offset: 25 }).setHTML(`
      <div style="font-size:14px">
        <strong><%= listing.title %></strong><br>
        <span><%= listing.location %>, <%= listing.country %></span>
      </div>
    `);

    new maplibregl.Marker({ color: "#dc3545" })
      .setLngLat(coords)
      .setPopup(popup)
      .addTo(map);

    document.getElementById("mapLoader").style.display = "none";
  } catch (err) {
    document.getElementById("mapLoader").innerText = "Map failed to load";
    console.log("Map error:", err);
  }
}
</script>
