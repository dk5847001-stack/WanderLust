<% layout("/layouts/boilerplate") -%>

<div class="container py-5">

  <!-- Title -->
  <h2 class="fw-bold"><%= listings.title %></h2>
  <p class="text-muted">📍 <%= listings.location %>, <%= listings.country %></p>

  <hr>

  <!-- ⭐ Reviews -->
  <h4>⭐ Reviews</h4>

  <p class="text-muted">
    Average:
    <strong><%= avgRating ? avgRating.toFixed(1) : "No rating" %></strong>
  </p>

  <!-- ================= REVIEW FORM ================= -->
  <form action="/listings/<%= listings._id %>/reviews" method="post" class="needs-validation" novalidate>

    <!-- ⭐ Rating -->
    <div class="mb-3">
      <label class="fw-semibold">Rating</label>

      <div class="star-rating">
  <% for(let i = 1; i <= 5; i++) { %>
    <input 
      type="radio" 
      class="rating-input"
      id="star<%= i %>" 
      name="review[rating]" 
      value="<%= i %>">
    <label for="star<%= i %>">★</label>
  <% } %>
</div>

      <div class="invalid-feedback d-block" id="ratingError" style="display:none;">
       
        <div class="valid-feedback">
        Looks good!
      </div>
      </div>
    </div>

    <!-- 📝 Comment -->
    <div class="mb-3">
      <textarea 
        name="review[comment]" 
        class="form-control" 
        rows="3" 
        placeholder="Write your review..." 
        required 
        minlength="10"></textarea>

      <div class="valid-feedback">
        Looks good!
      </div>

      <div class="invalid-feedback">
        Comment must be at least 10 characters long.
      </div>
    </div>

    <button class="btn btn-dark">Submit</button>
  </form>

  <hr>

  <!-- ================= REVIEW LIST ================= -->
  <% if(listings.reviews.length > 0) { %>
    <% listings.reviews.forEach(review => { %>

      <div class="card p-3 mb-3">
        <div class="d-flex justify-content-between">
          <strong>👤 User</strong>

          <span class="text-warning">
            <% for(let i = 1; i <= 5; i++) { %>
              <%= i <= review.rating ? "★" : "☆" %>
            <% } %>
          </span>
        </div>

        <p><%= review.comment %></p>

        <form method="post" action="/listings/<%= listings._id %>/reviews/<%= review._id %>?_method=DELETE">
          <button class="btn btn-sm btn-danger">Delete</button>
        </form>
      </div>

    <% }) %>
  <% } else { %>
    <p>No reviews yet.</p>
  <% } %>

</div>

<!-- ================= VALIDATION JS ================= -->
<script>
(() => {

  const forms = document.querySelectorAll(".needs-validation");

  forms.forEach(form => {

    const ratingInputs = form.querySelectorAll(".rating-input");
    const ratingError = form.querySelector("#ratingError");
    const textarea = form.querySelector("textarea");

    form.addEventListener("submit", function(e) {

      let ratingChecked = Array.from(ratingInputs).some(input => input.checked);
      let commentValid = textarea.value.trim().length >= 10;

      if (!ratingChecked || !commentValid) {
        e.preventDefault();
        e.stopPropagation();
      }

      // ⭐ rating error
      if (ratingError) {
        ratingError.style.display = ratingChecked ? "none" : "block";
      }

      // 📝 comment validation
      if (!commentValid) {
        textarea.classList.add("is-invalid");
        textarea.classList.remove("is-valid");
      } else {
        textarea.classList.add("is-valid");
        textarea.classList.remove("is-invalid");
      }

    });

    // ⭐ instant fix
    ratingInputs.forEach(input => {
      input.addEventListener("change", () => {
        if (ratingError) ratingError.style.display = "none";
      });
    });

    // 📝 live validation
    textarea.addEventListener("input", () => {
      if (textarea.value.trim().length >= 10) {
        textarea.classList.add("is-valid");
        textarea.classList.remove("is-invalid");
      } else {
        textarea.classList.add("is-invalid");
        textarea.classList.remove("is-valid");
      }
    });

  });

})();
</script>