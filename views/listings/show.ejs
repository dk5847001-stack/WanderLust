<% layout("/layouts/boilerplate") -%>

<div class="container py-5">

  <!-- ================= LISTING DETAILS ================= -->

  <!-- 👤 Owner Button -->
  <button type="button" 
    class="owner-btn btn btn-light rounded-pill shadow-sm"
    data-bs-toggle="popover"
    data-bs-placement="right"
    data-bs-title="👤 <%= listing.owner.username %>"
    data-bs-content="<%= listing.owner.email %>">

    👤 <span><%= listing.owner.username %></span>
  </button>

  <!-- Title -->
  <h2 class="fw-bold mt-3"><%= listing.title %></h2>
  <p class="text-muted">📍 <%= listing.location %>, <%= listing.country %></p>

  <!-- ================= ACTION BUTTONS ================= -->
  <% if(currUser && currUser._id.equals(listing.owner._id)){ %>
    <div class="d-flex gap-2 mt-3 mb-3">
      <a href="/listings/<%= listing._id %>/edit" 
         class="btn btn-outline-primary rounded-pill">
        ✏️ Edit
      </a>

      <form method="post" 
            action="/listings/<%= listing._id %>?_method=DELETE"
            onsubmit="return confirm('Are you sure you want to delete this listing?');">
        <button class="btn btn-outline-danger rounded-pill">
          🗑️ Delete
        </button>
      </form>
    </div>
  <% } %>

  <!-- ================= IMAGE + INFO ================= -->
  <div class="row mt-4">

    <div class="col-md-8">
      <img src="<%= listing.image.url %>" 
           class="img-fluid rounded shadow-sm"
           style="height:400px; width:100%; object-fit:cover;">
    </div>

    <div class="col-md-4">
      <div class="card p-3 shadow-sm">
        <h4>₹ <%= listing.price %> / night</h4>
        <p class="text-muted mt-2"><%= listing.description %></p>
      </div>
    </div>

  </div>

  <hr>

  <!-- ================= REVIEWS ================= -->

  <h4>⭐ Reviews</h4>

  <p class="text-muted">
    Average:
    <strong><%= avgRating ? avgRating.toFixed(1) : "No rating" %></strong>
  </p>

  <!-- ================= REVIEW FORM ================= -->

  <% if(currUser && !currUser._id.equals(listing.owner._id)){ %>

    <form action="/listings/<%= listing._id %>/reviews" 
          method="post" 
          class="needs-validation"
          novalidate>

      <!-- ⭐ Rating -->
      <div class="mb-3">
        <label class="fw-semibold">Rating</label>

        <div class="star-rating">
          <% for(let i = 1; i <= 5; i++) { %>
            <input type="radio" name="review[rating]" value="<%= i %>">
            <label>★</label>
          <% } %>
        </div>

        <div class="text-danger" id="ratingError" style="display:none;">
          Please select a rating.
        </div>
      </div>

      <!-- 📝 Comment -->
      <div class="mb-3">
        <textarea 
          name="review[comment]" 
          class="form-control"
          rows="3"
          placeholder="Write your review..."
          required minlength="10"></textarea>

        <div class="invalid-feedback">
          Comment must be at least 10 characters.
        </div>
      </div>

      <button class="btn btn-dark rounded-pill">Submit</button>
    </form>

  <% } else if(currUser){ %>

    <p class="text-muted">You cannot review your own listing.</p>

  <% } else { %>

    <p class="text-muted">Please login to write a review.</p>

  <% } %>

  <hr>

  <!-- ================= REVIEW LIST ================= -->

  <div class="row g-4">

    <% if(listing.reviews.length > 0) { %>

      <% listing.reviews.forEach(review => { %>

        <div class="col-md-6">
          <div class="card p-3 shadow-sm h-100">

            <div class="d-flex justify-content-between">

              <!-- 👤 Reviewer -->
              <strong>
                👤 <%= review.author?.username || "Anonymous" %>
              </strong>

              <!-- ⭐ Stars -->
              <span class="text-warning">
                <% for(let i = 1; i <= 5; i++) { %>
                  <%= i <= review.rating ? "★" : "☆" %>
                <% } %>
              </span>

            </div>

            <p class="mt-2"><%= review.comment %></p>

            <!-- 🗑️ Delete (ONLY AUTHOR) -->
            <% if(currUser && review.author && review.author._id.equals(currUser._id)){ %>
              <form method="post" 
                action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                <button class="btn btn-sm btn-outline-danger rounded-pill">
                  Delete
                </button>
              </form>
            <% } %>

          </div>
        </div>

      <% }) %>

    <% } else { %>
      <p class="text-muted">No reviews yet.</p>
    <% } %>

  </div>

</div>

<!-- ================= JS ================= -->
<script>
document.addEventListener("DOMContentLoaded", function () {

  // ✅ Popover init
  const popovers = document.querySelectorAll('[data-bs-toggle="popover"]');
  popovers.forEach(el => new bootstrap.Popover(el));

  // ✅ Form validation safe
  const form = document.querySelector(".needs-validation");

  if(form){
    const ratingInputs = form.querySelectorAll("input[type='radio']");
    const ratingError = document.getElementById("ratingError");
    const textarea = form.querySelector("textarea");

    form.addEventListener("submit", function (e) {

      let ratingChecked = Array.from(ratingInputs).some(input => input.checked);
      let commentValid = textarea.value.trim().length >= 10;

      if (!ratingChecked || !commentValid) {
        e.preventDefault();
      }

      ratingError.style.display = ratingChecked ? "none" : "block";
      textarea.classList.toggle("is-invalid", !commentValid);
    });

    ratingInputs.forEach(input => {
      input.addEventListener("change", () => {
        ratingError.style.display = "none";
      });
    });
  }

});
</script>