<% layout("/layouts/boilerplate") -%>

<div class="container py-5">

  <!-- ================= LISTING DETAILS ================= -->

  <h2 class="fw-bold"><%= listings.title %></h2>
  <p class="text-muted">📍 <%= listings.location %>, <%= listings.country %></p>

  <!-- ✅ ACTION BUTTONS -->
  <div class="d-flex gap-2 mt-3 mb-3">
    <a href="/listings/<%= listings._id %>/edit" 
       class="btn btn-outline-primary rounded-pill">
      ✏️ Edit
    </a>

    <form method="post" 
          action="/listings/<%= listings._id %>?_method=DELETE"
          onsubmit="return confirm('Are you sure you want to delete this listing?');">
      <button class="btn btn-outline-danger rounded-pill">
        🗑️ Delete
      </button>
    </form>
  </div>

  <div class="row mt-4">

    <!-- 🖼️ Image -->
    <div class="col-md-8">
      <img src="<%= listings.image.url %>" 
           class="img-fluid rounded shadow-sm"
           style="height:400px; width:100%; object-fit:cover;">
    </div>

    <!-- 💰 Price + Info -->
    <div class="col-md-4">
      <div class="card p-3 shadow-sm">
        <h4>₹ <%= listings.price %> / night</h4>
        <p class="text-muted mt-2"><%= listings.description %></p>
      </div>
    </div>

  </div>

  <hr>

  <!-- ================= REVIEWS ================= -->

  <h4>⭐ Reviews</h4>

  <p class="text-muted">
    Average:
    <strong><%= avgRating ? avgRating.toFixed(1) : "No rating" %></strong>
  </p>

  <!-- ================= REVIEW FORM ================= -->
  <form action="/listings/<%= listings._id %>/reviews" 
        method="post" 
        class="needs-validation" 
        novalidate>

    <!-- ⭐ Rating -->
    <div class="mb-3">
      <label class="fw-semibold">Rating</label>

      <div class="star-rating">
        <% for(let i = 1; i <= 5; i++) { %>
          <input type="radio" 
                 class="rating-input" 
                 name="review[rating]" 
                 value="<%= i %>">
          <label>★</label>
        <% } %>
      </div>

      <div class="text-danger" id="ratingError" style="display:none;">
        Please select a rating.
      </div>
    </div>

    <!-- 📝 Comment -->
    <div class="mb-3">
      <textarea 
        name="review[comment]" 
        class="form-control" 
        rows="3" 
        placeholder="Write your review..." 
        required 
        minlength="10"></textarea>

      <div class="invalid-feedback">
        Comment must be at least 10 characters long.
      </div>
    </div>

    <button class="btn btn-dark rounded-pill">Submit</button>
  </form>

  <hr>

  <!-- ================= REVIEW LIST ================= -->
  <div class="row g-4">

    <% if(listings.reviews.length > 0) { %>
      <% listings.reviews.forEach(review => { %>

        <div class="col-md-6">
          <div class="card p-3 shadow-sm h-100">

            <div class="d-flex justify-content-between">
              <strong>👤 User</strong>

              <span class="text-warning">
                <% for(let i = 1; i <= 5; i++) { %>
                  <%= i <= review.rating ? "★" : "☆" %>
                <% } %>
              </span>
            </div>

            <p class="mt-2"><%= review.comment %></p>

            <form method="post" 
                  action="/listings/<%= listings._id %>/reviews/<%= review._id %>?_method=DELETE">
              <button class="btn btn-sm btn-outline-danger rounded-pill">
                Delete
              </button>
            </form>

          </div>
        </div>

      <% }) %>
    <% } else { %>
      <p>No reviews yet.</p>
    <% } %>

  </div>

</div>

<!-- ================= VALIDATION JS ================= -->
<script>
(() => {

  const form = document.querySelector(".needs-validation");
  const ratingInputs = document.querySelectorAll(".rating-input");
  const ratingError = document.getElementById("ratingError");
  const textarea = document.querySelector("textarea");

  form.addEventListener("submit", function(e) {

    let ratingChecked = Array.from(ratingInputs).some(input => input.checked);
    let commentValid = textarea.value.trim().length >= 10;

    if (!ratingChecked || !commentValid) {
      e.preventDefault();
      e.stopPropagation();
    }

    ratingError.style.display = ratingChecked ? "none" : "block";

    if (!commentValid) {
      textarea.classList.add("is-invalid");
    } else {
      textarea.classList.remove("is-invalid");
    }

  });

  ratingInputs.forEach(input => {
    input.addEventListener("change", () => {
      ratingError.style.display = "none";
    });
  });

})();
</script>