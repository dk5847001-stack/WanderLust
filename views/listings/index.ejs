<% layout("/layouts/boilerplate") -%>

<!-- ✅ MAPLIBRE REQUIRED (IMPORTANT) -->
<link href="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.css" rel="stylesheet" />
<script src="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.js"></script>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>
/* 🔥 FILTER BAR */
#filters {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  align-items: center;
}

.filter {
  padding: 6px 14px;
  border-radius: 20px;
  background: #f1f1f1;
  cursor: pointer;
  transition: .3s;
  font-size: 14px;
}

.filter:hover {
  background: #0d6efd;
  color: white;
}

.filter.active {
  background: #0d6efd;
  color: white;
  font-weight: 600;
}

/* 🔥 CARD */
.listing-card {
  border-radius: 18px;
  overflow: hidden;
  transition: .3s;
}

.listing-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 10px 25px rgba(0,0,0,0.15);
}

.listing-img {
  height: 200px;
  object-fit: cover;
}

/* 🔥 PRICE */
.price {
  font-weight: bold;
  color: #198754;
}

/* 🔥 EMPTY */
.empty {
  text-align: center;
  margin-top: 50px;
  color: gray;
}
</style>

<div class="container py-4">

  <!-- 🔍 SEARCH -->
  <input 
    type="text"
    id="searchInput"
    class="form-control rounded-pill mb-3"
    placeholder="🔍 Search location, country, title..."
  >

  <!-- 🎯 FILTERS -->
  <div id="filters" class="mb-4">

    <% const filters = ["Trending","Rooms","Cities","Mountains","Pools","Camping","Farms","Homes"]; %>

    <div class="filter active" data-category="">All</div>

    <% filters.forEach(f => { %>
      <div class="filter" data-category="<%= f %>"><%= f %></div>
    <% }) %>

  </div>

  <!-- LISTINGS -->
  <div class="row g-4" id="listingContainer"></div>

  <!-- MAP -->
  <h5 class="mt-5">📍 Explore on Map</h5>
  <div id="map" style="height:400px; border-radius:14px;"></div>

</div>

<script>
let currentCategory = "";
let currentSearch = "";

let map;
let markers = [];

// 🔥 DEBOUNCE
function debounce(fn, delay){
  let timeout;
  return (...args)=>{
    clearTimeout(timeout);
    timeout = setTimeout(()=>fn(...args), delay);
  }
}

// ================= FETCH =================
async function fetchListings() {
  try {
    const res = await fetch(`/listings/api?category=${currentCategory}&search=${currentSearch}`);
    const data = await res.json();

    renderListings(data);
    updateMap(data);
  } catch (err) {
    console.error("Fetch Error:", err);
  }
}

// ================= RENDER =================
function renderListings(listings) {
  const container = document.getElementById("listingContainer");

  if (!listings.length) {
    container.innerHTML = `
      <div class="empty">
        <i class="fa fa-search fa-2x mb-2"></i>
        <p>No listings found</p>
      </div>
    `;
    return;
  }

  container.innerHTML = listings.map(l => `
    <div class="col-lg-3 col-md-4 col-sm-6">
      <div class="card listing-card shadow-sm">

        <img src="${l.image?.url || 'https://via.placeholder.com/300'}" class="listing-img w-100">

        <div class="card-body">
          <h6 class="fw-bold">${l.title}</h6>
          <p class="text-muted mb-1">${l.location}, ${l.country}</p>
          <p class="price">₹ ${l.price}</p>

          <a href="/listings/${l._id}" class="btn btn-sm btn-dark w-100">
            View Details
          </a>
        </div>

      </div>
    </div>
  `).join("");
}

// ================= FILTER =================
document.querySelectorAll(".filter").forEach(btn => {
  btn.addEventListener("click", () => {

    currentCategory = btn.dataset.category;

    document.querySelectorAll(".filter").forEach(f => f.classList.remove("active"));
    btn.classList.add("active");

    fetchListings();
  });
});

// ================= SEARCH =================
const searchHandler = debounce((e)=>{
  currentSearch = e.target.value;
  fetchListings();
}, 400);

document.getElementById("searchInput").addEventListener("input", searchHandler);

// ================= MAP =================
function initMap() {
  const apiKey = "FmtEvoD5gfMXGun2J9YQ"; // ⚠️ replace this

  map = new maplibregl.Map({
    container: "map",
    style: `https://api.maptiler.com/maps/streets/style.json?key=${apiKey}`,
    center: [78.9629, 20.5937],
    zoom: 4
  });
}

function updateMap(listings) {
  if (!map) return;

  markers.forEach(m => m.remove());
  markers = [];

  listings.forEach(l => {
    if (!l.geometry || !l.geometry.coordinates) return;

    const marker = new maplibregl.Marker({ color: "#ff385c" })
      .setLngLat(l.geometry.coordinates)
      .setPopup(
        new maplibregl.Popup().setHTML(`<b>${l.title}</b>`)
      )
      .addTo(map);

    markers.push(marker);
  });
}

// ================= INIT =================
window.onload = () => {
  initMap();      // ✅ map start
  fetchListings(); // ✅ auto load listings
};
</script>