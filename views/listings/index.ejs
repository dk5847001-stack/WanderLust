<% layout("/layouts/boilerplate") -%>

<!-- ✅ Bootstrap Icons (IMPORTANT) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<body>
<div class="container py-4">

    <!-- ================= LISTINGS ================= -->

    <div class="row g-4">

        <% for(let listing of allListings){ %>
        <div class="col-12 col-sm-6 col-md-4 col-lg-3">

            <div class="card h-100 shadow-sm rounded-4 overflow-hidden border-0">

                <!-- Image -->
                <div class="position-relative">
                    <img src="<%= listing.image.url %>" 
                         class="card-img-top"
                         style="height:200px; object-fit:cover;">

                    <!-- Price Badge -->
                    <div class="position-absolute bottom-0 start-0 m-2">
                        <span class="badge bg-dark bg-opacity-75 px-3 py-2 rounded-pill">
                            <% if (listing.price) { %>
                                ₹ <%= listing.price.toLocaleString("en-IN") %>
                            <% } else { %>
                                N/A
                            <% } %>
                        </span>
                    </div>
                </div>

                <!-- Body -->
                <div class="card-body d-flex flex-column">

                    <h6 class="fw-semibold text-truncate">
                        <%= listing.title %>
                    </h6>

                    <p class="text-muted small flex-grow-1">
                        <%= listing.description.substring(0, 60) %>...
                    </p>

                    <a href="/listings/<%= listing._id %>" 
                       class="btn btn-primary rounded-pill mt-auto">
                        View Details
                    </a>

                </div>
            </div>

        </div>
        <% } %>

    </div>
</div>



</body>