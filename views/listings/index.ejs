<% layout("/layouts/boilerplate") -%>

<section class="page-stack">
  <section class="hero-card">
    <div class="section-heading mb-4">
      <div>
        <span class="eyebrow mb-3">
          <i class="bi bi-grid-1x2"></i>
          Curated inventory
        </span>
        <h1 class="page-title headline-gradient">Find the right stay faster with immersive filters.</h1>
        <p class="page-subtitle mb-0">Browse premium properties, refine by category, and explore every destination with map-backed discovery.</p>
      </div>
    </div>

    <div class="listing-shell">
      <div class="toolbar-grid mb-4">
        <div class="search-shell">
          <i class="bi bi-search"></i>
          <input type="text" id="searchInput" class="form-control" placeholder="Search by title, location, or country">
        </div>

        <div class="meta-row justify-content-lg-end">
          <span class="stat-pill"><i class="bi bi-lightning-charge"></i> Live filtering</span>
          <span class="stat-pill"><i class="bi bi-phone"></i> Responsive cards</span>
        </div>
      </div>

      <div id="filters" class="filter-bar mb-4">
        <% const filters = ["Trending","Rooms","Cities","Mountains","Pools","Camping","Farms","Homes"]; %>
        <button class="filter-chip active" data-category="" type="button">All</button>
        <% filters.forEach(f => { %>
          <button class="filter-chip" data-category="<%= f %>" type="button"><%= f %></button>
        <% }) %>
      </div>

      <div class="listing-grid" id="listingContainer"></div>
    </div>
  </section>

  <section class="map-shell position-relative">
    <div class="section-heading">
      <div>
        <span class="mini-label">Geo view</span>
        <h2>Explore the collection on the map</h2>
      </div>
      <p class="muted-copy mb-0">Use location context to spot clusters, cities, and destination-ready options faster.</p>
    </div>
    <div class="map-frame" id="map"></div>
  </section>
</section>

<script>
let currentCategory = "";
let currentSearch = "";
let map;
let markers = [];

function debounce(fn, delay) {
  let timeout;
  return (...args) => {
    clearTimeout(timeout);
    timeout = setTimeout(() => fn(...args), delay);
  };
}

async function fetchListings() {
  try {
    const res = await fetch(`/listings/api?category=${encodeURIComponent(currentCategory)}&search=${encodeURIComponent(currentSearch)}`);
    const data = await res.json();
    renderListings(data);
    updateMap(data);
  } catch (err) {
    console.error("Fetch Error:", err);
  }
}

function renderListings(listings) {
  const container = document.getElementById("listingContainer");

  if (!listings.length) {
    container.innerHTML = `
      <div class="empty-state glass-panel" style="grid-column: 1 / -1;">
        <i class="bi bi-search-heart"></i>
        <h4 class="mt-3">No listings matched your search</h4>
        <p class="muted-copy mb-0">Try a broader keyword or switch categories to continue exploring.</p>
      </div>
    `;
    return;
  }

  container.innerHTML = listings.map((listing) => `
    <article class="listing-card">
      <div class="listing-card-media">
        <img src="${listing.image?.url || 'https://via.placeholder.com/600x400'}" alt="${listing.title}">
      </div>
      <div class="listing-card-body">
        <div class="meta-row mb-2">
          <span class="category-pill">${listing.category || "Featured"}</span>
        </div>
        <h5 class="fw-semibold mb-2">${listing.title}</h5>
        <p class="muted-copy mb-3">${listing.location}, ${listing.country}</p>
        <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap">
          <span class="price-tag">&#8377; ${Number(listing.price).toLocaleString("en-IN")} / night</span>
          <a href="/listings/${listing._id}" class="btn btn-dark btn-sm">View Details</a>
        </div>
      </div>
    </article>
  `).join("");
}

document.querySelectorAll(".filter-chip").forEach((button) => {
  button.addEventListener("click", () => {
    currentCategory = button.dataset.category;
    document.querySelectorAll(".filter-chip").forEach((chip) => chip.classList.remove("active"));
    button.classList.add("active");
    fetchListings();
  });
});

document.getElementById("searchInput").addEventListener("input", debounce((event) => {
  currentSearch = event.target.value.trim();
  fetchListings();
}, 350));

function initMap() {
  const apiKey = "FmtEvoD5gfMXGun2J9YQ";

  map = new maplibregl.Map({
    container: "map",
    style: `https://api.maptiler.com/maps/streets/style.json?key=${apiKey}`,
    center: [78.9629, 20.5937],
    zoom: 4
  });

  map.addControl(new maplibregl.NavigationControl(), "top-right");
}

function updateMap(listings) {
  if (!map) {
    return;
  }

  markers.forEach((marker) => marker.remove());
  markers = [];

  listings.forEach((listing) => {
    if (!listing.geometry || !listing.geometry.coordinates) {
      return;
    }

    const marker = new maplibregl.Marker({ color: "#35d0ff" })
      .setLngLat(listing.geometry.coordinates)
      .setPopup(new maplibregl.Popup().setHTML(`<strong>${listing.title}</strong><br>${listing.location}`))
      .addTo(map);

    markers.push(marker);
  });
}

window.addEventListener("load", () => {
  initMap();
  fetchListings();
});
</script>
