<% layout("/layouts/boilerplate") -%>

<section class="mb-4">
  <div class="p-4 p-md-5 bg-white border rounded-4 shadow-sm">
    <div class="row g-4 align-items-center">
      <div class="col-lg-8">
        <span class="badge text-bg-primary mb-3">All Listings</span>
        <h1 class="display-6 fw-bold mb-2">Explore properties with clean Bootstrap cards</h1>
        <p class="text-muted mb-0">Search, filter, and browse listings with a simpler interface and better placeholder experience.</p>
      </div>
      <div class="col-lg-4">
        <div class="row g-3 text-center">
          <div class="col-6">
            <div class="border rounded-4 bg-light p-3 h-100">
              <div class="fw-bold">Live</div>
              <small class="text-muted">Filtering</small>
            </div>
          </div>
          <div class="col-6">
            <div class="border rounded-4 bg-light p-3 h-100">
              <div class="fw-bold">Responsive</div>
              <small class="text-muted">Cards</small>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="card border-0 shadow-sm mb-4">
  <div class="card-body p-3 p-md-4">
    <div class="row g-3 align-items-center mb-3">
      <div class="col-lg-6">
        <input type="text" id="searchInput" class="form-control" placeholder="Search by title, location, or country">
      </div>
      <div class="col-lg-6">
        <div id="filters" class="d-flex flex-wrap gap-2">
          <% const filters = ["Trending","Rooms","Cities","Mountains","Pools","Camping","Farms","Homes"]; %>
          <button class="btn btn-primary btn-sm filter-chip active" data-category="" type="button">All</button>
          <% filters.forEach(f => { %>
            <button class="btn btn-outline-primary btn-sm filter-chip" data-category="<%= f %>" type="button"><%= f %></button>
          <% }) %>
        </div>
      </div>
    </div>

    <div class="row g-4" id="listingContainer">
      <% for(let i = 0; i < 8; i++) { %>
        <div class="col-xl-3 col-lg-4 col-md-6">
          <div class="card h-100 shadow-sm">
            <svg class="bd-placeholder-img card-img-top" width="100%" height="220" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Placeholder">
              <rect width="100%" height="100%" fill="#dee2e6"></rect>
              <text x="50%" y="50%" fill="#6c757d" dy=".3em" text-anchor="middle">Loading...</text>
            </svg>
            <div class="card-body">
              <p class="card-text placeholder-glow mb-2">
                <span class="placeholder col-4"></span>
              </p>
              <h5 class="card-title placeholder-glow">
                <span class="placeholder col-8"></span>
              </h5>
              <p class="card-text placeholder-glow mb-3">
                <span class="placeholder col-10"></span>
              </p>
              <p class="card-text placeholder-glow mb-3">
                <span class="placeholder col-5"></span>
              </p>
              <a class="btn btn-dark disabled placeholder col-12" aria-disabled="true"></a>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</section>

<section class="card border-0 shadow-sm">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
      <div>
        <h2 class="h4 mb-1">Explore on Map</h2>
        <p class="text-muted mb-0">Location overview for all visible listings.</p>
      </div>
    </div>
    <div id="map" class="rounded-3 border" style="height: 400px;"></div>
  </div>
</section>

<script>
let currentCategory = "";
let currentSearch = "";
let map;
let markers = [];

function debounce(fn, delay) {
  let timeout;
  return (...args) => {
    clearTimeout(timeout);
    timeout = setTimeout(() => fn(...args), delay);
  };
}

function fallbackImage(title = "Listing") {
  const safeTitle = String(title).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
  return `data:image/svg+xml;utf8,
    <svg xmlns='http://www.w3.org/2000/svg' width='600' height='400' viewBox='0 0 600 400'>
      <rect width='600' height='400' fill='%23dee2e6'/>
      <text x='50%25' y='48%25' text-anchor='middle' fill='%236c757d' font-size='28' font-family='Arial'>WanderLust</text>
      <text x='50%25' y='58%25' text-anchor='middle' fill='%236c757d' font-size='18' font-family='Arial'>${safeTitle}</text>
    </svg>`;
}

async function fetchListings() {
  try {
    const res = await fetch(`/listings/api?category=${encodeURIComponent(currentCategory)}&search=${encodeURIComponent(currentSearch)}`);
    const data = await res.json();
    renderListings(data);
    updateMap(data);
  } catch (err) {
    console.error("Fetch Error:", err);
  }
}

function renderListings(listings) {
  const container = document.getElementById("listingContainer");

  if (!listings.length) {
    container.innerHTML = `
      <div class="col-12">
        <div class="alert alert-secondary text-center mb-0">
          <i class="bi bi-search me-2"></i>No listings matched your search.
        </div>
      </div>
    `;
    return;
  }

  container.innerHTML = listings.map((listing) => `
    <div class="col-xl-3 col-lg-4 col-md-6">
      <div class="card h-100 shadow-sm">
        <img src="${listing.image?.url || fallbackImage(listing.title)}" class="card-img-top" alt="${listing.title}" style="height: 220px; object-fit: cover;">
        <div class="card-body d-flex flex-column">
          <span class="badge text-bg-light border text-dark mb-2 align-self-start">${listing.category || "Featured"}</span>
          <h5 class="card-title">${listing.title}</h5>
          <p class="card-text text-muted mb-2">${listing.location}, ${listing.country}</p>
          <p class="fw-semibold text-success mb-3">&#8377; ${Number(listing.price).toLocaleString("en-IN")} / night</p>
          <a href="/listings/${listing._id}" class="btn btn-dark mt-auto">View Details</a>
        </div>
      </div>
    </div>
  `).join("");
}

document.querySelectorAll(".filter-chip").forEach((button) => {
  button.addEventListener("click", () => {
    currentCategory = button.dataset.category;
    document.querySelectorAll(".filter-chip").forEach((chip) => {
      chip.classList.remove("btn-primary", "active");
      chip.classList.add("btn-outline-primary");
    });
    button.classList.remove("btn-outline-primary");
    button.classList.add("btn-primary", "active");
    fetchListings();
  });
});

document.getElementById("searchInput").addEventListener("input", debounce((event) => {
  currentSearch = event.target.value.trim();
  fetchListings();
}, 350));

function initMap() {
  const apiKey = "FmtEvoD5gfMXGun2J9YQ";

  map = new maplibregl.Map({
    container: "map",
    style: `https://api.maptiler.com/maps/streets/style.json?key=${apiKey}`,
    center: [78.9629, 20.5937],
    zoom: 4
  });

  map.addControl(new maplibregl.NavigationControl(), "top-right");
}

function updateMap(listings) {
  if (!map) {
    return;
  }

  markers.forEach((marker) => marker.remove());
  markers = [];

  listings.forEach((listing) => {
    if (!listing.geometry || !listing.geometry.coordinates) {
      return;
    }

    const marker = new maplibregl.Marker({ color: "#dc3545" })
      .setLngLat(listing.geometry.coordinates)
      .setPopup(new maplibregl.Popup().setHTML(`<strong>${listing.title}</strong><br>${listing.location}`))
      .addTo(map);

    markers.push(marker);
  });
}

window.addEventListener("load", () => {
  initMap();
  fetchListings();
});
</script>
