<% layout("/layouts/boilerplate") -%>

    <body>
        <div class="container py-4">
            <div class="row g-4">

                <% for(let listing of allListings){ %>
                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">

                        <div
                            class="card listing-card h-100 border-0 shadow-sm rounded-4 overflow-hidden position-relative">

                            <!-- Image -->
                            <div class="position-relative">
                                <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image"
                                    style="height: 200px; object-fit: cover;">

                                <!-- Wishlist Icon -->
                                <div class="position-absolute top-0 end-0 m-2">
                                    <button class="btns btn btn-light rounded-circle shadow-sm p-2 wishlist-btn">
                                        <i class="fa-regular fa-heart"></i>
                                    </button>
                                </div>

                                <!-- Price Badge -->
                                <div class="position-absolute bottom-0 start-0 m-2">
                                    <span class="badge bg-dark bg-opacity-75 px-3 py-2 rounded-pill">
                                        <% if (listing.price) { %>
                                            ₹ <%= listing.price.toLocaleString("en-IN") %> / night
                                                <% } else { %>
                                                    Price not available
                                                    <% } %>
                                    </span>
                                </div>
                            </div>

                            <!-- Body -->
                            <div class="card-body d-flex flex-column">

                                <h6 class="card-title fw-semibold mb-1 text-truncate">
                                    <%= listing.title %>
                                </h6>

                                <p class="text-muted small mb-3 flex-grow-1">
                                    <%= listing.description.substring(0, 70) %>...
                                </p>
                                <div class="a">
                                    <a href="/listings/<%= listing._id %>"
                                        class="btn btn-primary w-100 rounded-pill fw-semibold">
                                        View Details
                                    </a>
                                </div>
                            </div>
                        </div>

                    </div>
                    <% } %>

            </div>
        </div>
    </body>