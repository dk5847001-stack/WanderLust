<% layout("layouts/boilerplate") -%>

<section class="page-stack">
  <section class="hero-card">
    <div class="section-heading">
      <div>
        <span class="eyebrow mb-3"><i class="bi bi-inboxes"></i> Message center</span>
        <h1 class="page-title headline-gradient">All user messages in one responsive workspace.</h1>
        <p class="page-subtitle mb-0">Review incoming conversations, update message records, and manage contact interactions with a cleaner dashboard feel.</p>
      </div>
    </div>

    <% if (messages && messages.length > 0) { %>
      <div class="dashboard-table">
        <div class="table-responsive">
          <table class="table table-dark table-hover align-middle text-center">
            <thead>
              <tr>
                <th>#</th>
                <th>Name</th>
                <th>Email</th>
                <th>Subject</th>
                <th>Message</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% messages.forEach((message, index) => { %>
                <tr>
                  <td><%= index + 1 %></td>
                  <td class="fw-semibold"><%= message.name %></td>
                  <td><%= message.email %></td>
                  <td><span class="category-pill"><%= message.subject %></span></td>
                  <td style="max-width: 280px;">
                    <span class="text-truncate d-inline-block w-100"><%= message.message %></span>
                  </td>
                  <td>
                    <div class="d-flex justify-content-center gap-2 flex-wrap">
                      <a href="/message/<%= message._id %>/edit" class="btn btn-outline-warning btn-sm">Edit</a>
                      <form method="post" action="/message/<%= message._id %>?_method=DELETE">
                        <button class="btn btn-outline-danger btn-sm" type="submit">Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } else { %>
      <div class="empty-state glass-panel">
        <i class="bi bi-chat-square-heart"></i>
        <h4 class="mt-3">No messages found</h4>
        <p class="muted-copy mb-0">The inbox is currently clear.</p>
      </div>
    <% } %>
  </section>
</section>
