<% layout("layouts/boilerplate") -%>

<section class="form-wrap">
  <div class="form-shell">
    <div class="section-heading">
      <div>
        <span class="eyebrow mb-3"><i class="bi bi-pencil"></i> Message editor</span>
        <h1 class="page-title headline-gradient">Update a saved contact message.</h1>
        <p class="page-subtitle mb-0">Edit user information or message content with a cleaner admin flow.</p>
      </div>
    </div>

    <form method="post" action="/message/<%= message._id %>?_method=PUT">
      <div class="row g-4">
        <div class="col-md-6">
          <label class="form-label fw-semibold">Name</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-person-fill"></i></span>
            <input type="text" name="name" class="form-control" value="<%= message.name %>" required>
          </div>
        </div>

        <div class="col-md-6">
          <label class="form-label fw-semibold">Email</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-envelope-fill"></i></span>
            <input type="email" name="email" class="form-control" value="<%= message.email %>" required>
          </div>
        </div>

        <div class="col-12">
          <label class="form-label fw-semibold">Subject</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-chat-left-text-fill"></i></span>
            <input type="text" name="subject" class="form-control" value="<%= message.subject %>" required>
          </div>
        </div>

        <div class="col-12">
          <label class="form-label fw-semibold">Message</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-pencil-fill"></i></span>
            <textarea name="message" class="form-control" rows="5" required><%= message.message %></textarea>
          </div>
        </div>

        <div class="col-12 d-flex flex-wrap gap-3">
          <a href="/message/read" class="btn btn-outline-secondary">Back</a>
          <button type="submit" class="btn btn-primary">Update Message</button>
        </div>
      </div>
    </form>
  </div>
</section>
