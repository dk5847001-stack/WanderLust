<% layout("/layouts/boilerplate") -%>

<section class="page-stack">
  <section class="hero-card">
    <div class="section-heading">
      <div>
        <span class="eyebrow mb-3"><i class="bi bi-people"></i> Subscriber dashboard</span>
        <h1 class="page-title headline-gradient">Manage newsletter and update subscribers elegantly.</h1>
        <p class="page-subtitle mb-0">A responsive table experience for keeping track of audience signups across devices.</p>
      </div>
    </div>

    <% if (subscriber && subscriber.length > 0) { %>
      <div class="dashboard-table">
        <div class="table-responsive">
          <table class="table table-dark table-hover align-middle text-center">
            <thead>
              <tr>
                <th>#</th>
                <th>Email</th>
                <th>Source</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% subscriber.forEach((sub, index) => { %>
                <tr>
                  <td><%= index + 1 %></td>
                  <td class="fw-semibold"><%= sub.email %></td>
                  <td><span class="category-pill">Footer</span></td>
                  <td>
                    <div class="d-flex justify-content-center gap-2 flex-wrap">
                      <a href="/subscriber/<%= sub._id %>/edit" class="btn btn-outline-warning btn-sm">Edit</a>
                      <form method="post" action="/subscriber/<%= sub._id %>?_method=DELETE">
                        <button class="btn btn-outline-danger btn-sm" type="submit">Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } else { %>
      <div class="empty-state glass-panel">
        <i class="bi bi-envelope-paper-heart"></i>
        <h4 class="mt-3">No subscribers found</h4>
        <p class="muted-copy mb-0">New audience signups will appear here.</p>
      </div>
    <% } %>
  </section>
</section>
