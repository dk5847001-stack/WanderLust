<% layout("/layouts/boilerplate") -%>

<div class="card border-0 shadow-sm">
  <div class="card-body p-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
      <div>
        <h1 class="h3 fw-bold mb-1">Subscribers</h1>
        <p class="text-muted mb-0">Manage newsletter subscribers in a simple table.</p>
      </div>
    </div>

    <% if (subscriber && subscriber.length > 0) { %>
      <div class="table-responsive">
        <table class="table table-hover align-middle">
          <thead class="table-light">
            <tr>
              <th>#</th>
              <th>Email</th>
              <th>Source</th>
              <th class="text-center">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% subscriber.forEach((sub, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td class="fw-semibold"><%= sub.email %></td>
                <td><span class="badge text-bg-light border text-dark">Footer</span></td>
                <td class="text-center">
                  <div class="d-flex justify-content-center gap-2 flex-wrap">
                    <a href="/subscriber/<%= sub._id %>/edit" class="btn btn-outline-warning btn-sm">Edit</a>
                    <form method="post" action="/subscriber/<%= sub._id %>?_method=DELETE">
                      <button class="btn btn-outline-danger btn-sm" type="submit">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="alert alert-secondary mb-0">No subscribers found.</div>
    <% } %>
  </div>
</div>
