<% layout("/layouts/boilerplate") -%>

<body>
  
  <div class="container mt-5">
        <h2 class="mb-4 text-center fw-bold">📧 Subscribers List</h2>

    <% if (subscriber && subscriber.length > 0) { %>

      <div class="table-responsive shadow-sm rounded">
        <table class="table table-striped table-hover align-middle text-center">

          <thead class="table-dark">
            <tr>
              <th>#</th>
              <th>Email</th>
              <th>Source</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody>
            <% subscriber.forEach((sub, index) => { %>
              <tr>
                <td><%= index + 1 %></td>

                <td class="fw-semibold">
                  <%= sub.email %>
                </td>

                <td>
                  <span class="badge bg-primary">Footer</span>
                </td>

                <td>
                  <!-- Edit (optional) -->
                  <a href="/subscriber/<%=sub._id%>/edit" class="btn btn-sm btn-outline-warning me-2">
                    <i class="fa-solid fa-pen"></i>
                  </a>

                  <!-- Delete -->
                  <form method="post" action="/subscriber/<%= sub._id %>?_method=DELETE" class="d-inline">
                    <button class="btn btn-sm btn-outline-danger">
                      <i class="fa-solid fa-trash"></i>
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>

        </table>
      </div>

    <% } else { %>

      <div class="text-center mt-5">
        <p class="text-muted">No subscribers found 😔</p>
      </div>

    <% } %>

  </div>
</body>