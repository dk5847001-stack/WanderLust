<% layout("/layouts/boilerplate") -%>

<section class="mb-4">
  <div class="p-4 p-md-5 bg-white border rounded-4 shadow-sm">
    <div class="row align-items-center g-4">
      <div class="col-lg-6">
        <span class="badge text-bg-danger mb-3">Welcome to WanderLust</span>
        <h1 class="display-5 fw-bold mb-3">Discover great stays for your next journey</h1>
        <p class="lead text-muted mb-4">
          Browse curated listings, explore popular destinations, and manage travel stays with a clean and professional experience.
        </p>
        <div class="d-flex flex-wrap gap-3">
          <a href="/listings" class="btn btn-primary btn-lg">Explore Listings</a>
          <a href="/listings/new" class="btn btn-outline-dark btn-lg">Add Listing</a>
        </div>
      </div>

      <div class="col-lg-6">
        <img src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=1400&q=80"
          alt="Travel stay" class="img-fluid rounded-4 shadow-sm w-100" style="max-height: 420px; object-fit: cover;">
      </div>
    </div>
  </div>
</section>

<section class="mb-4">
  <div class="row g-4">
    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm">
        <div class="card-body text-center p-4">
          <div class="mb-3 text-danger fs-2"><i class="bi bi-house-door-fill"></i></div>
          <h5 class="card-title fw-semibold">Premium Listings</h5>
          <p class="card-text text-muted mb-0">Browse quality stays with complete details, pricing, and polished presentation.</p>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm">
        <div class="card-body text-center p-4">
          <div class="mb-3 text-primary fs-2"><i class="bi bi-geo-alt-fill"></i></div>
          <h5 class="card-title fw-semibold">Top Locations</h5>
          <p class="card-text text-muted mb-0">Explore destinations using city, country, category, and map-based context.</p>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm">
        <div class="card-body text-center p-4">
          <div class="mb-3 text-success fs-2"><i class="bi bi-shield-check"></i></div>
          <h5 class="card-title fw-semibold">Trusted Platform</h5>
          <p class="card-text text-muted mb-0">Manage listings, reviews, and sessions through secure and familiar workflows.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section>
  <div class="card border-0 shadow-sm">
    <div class="card-body p-4 p-md-5 text-center">
      <h2 class="fw-bold mb-3">Ready to start exploring?</h2>
      <p class="text-muted mb-4">Create an account, browse destinations, or publish your own listing in just a few steps.</p>
      <div class="d-flex justify-content-center flex-wrap gap-3">
        <a href="/register" class="btn btn-primary">Create Account</a>
        <a href="/listings" class="btn btn-outline-secondary">Browse Listings</a>
      </div>
    </div>
  </div>
</section>
