<% layout("/layouts/boilerplate") -%>

<section class="page-stack">
  <section class="page-hero">
    <div class="hero-card">
      <div class="hero-grid">
        <div class="hero-copy">
          <span class="eyebrow mb-3">
            <i class="bi bi-stars"></i>
            Futuristic travel stays
          </span>

          <h1 class="page-title headline-gradient mb-3">
            Discover extraordinary stays with a cinematic, next-gen booking vibe.
          </h1>

          <p class="page-subtitle mb-4">
            Browse curated destinations, premium homes, mountain escapes, and city hideouts through an immersive platform designed for modern explorers and smart hosts.
          </p>

          <div class="d-flex flex-wrap gap-3 responsive-stack">
            <a href="/listings" class="btn btn-primary btn-lg">Explore Listings</a>
            <a href="/listings/new" class="btn btn-outline-secondary btn-lg">Launch a New Listing</a>
          </div>

          <div class="stats-grid mt-4">
            <article class="metric-card">
              <span class="mini-label">Live inventory</span>
              <h3 class="mb-1">500+</h3>
              <p class="muted-copy mb-0">High-quality listings with detailed discovery.</p>
            </article>
            <article class="metric-card">
              <span class="mini-label">Locations</span>
              <h3 class="mb-1">100+</h3>
              <p class="muted-copy mb-0">Destinations from cities to nature-forward stays.</p>
            </article>
            <article class="metric-card">
              <span class="mini-label">Support</span>
              <h3 class="mb-1">24/7</h3>
              <p class="muted-copy mb-0">Always-on help for hosts, guests, and explorers.</p>
            </article>
          </div>
        </div>

        <div class="hero-visual">
          <div class="hero-shot">
            <img src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=1400&q=80"
              alt="Luxury stay exterior">
          </div>

          <div class="floating-chip top">
            <i class="bi bi-geo-alt-fill text-primary"></i>
            <span>Location intelligence with MapTiler</span>
          </div>

          <div class="floating-chip bottom">
            <i class="bi bi-shield-check text-success"></i>
            <span>Secure sessions, reviews, hosting tools</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="section-heading">
      <div>
        <span class="mini-label">Why WanderLust</span>
        <h2>Designed to feel premium on every screen.</h2>
      </div>
      <p class="muted-copy mb-0">Fast discovery, rich listing details, and clean host workflows across laptop, tablet, and mobile.</p>
    </div>

    <div class="feature-grid">
      <article class="feature-card">
        <div class="owner-badge mb-3">
          <i class="bi bi-house-heart text-danger"></i>
          Premium inventory
        </div>
        <h5 class="fw-semibold">Curated stays with visual depth</h5>
        <p class="muted-copy mb-0">Each listing is built for confident browsing with imagery, pricing, categories, and destination context.</p>
      </article>

      <article class="feature-card">
        <div class="owner-badge mb-3">
          <i class="bi bi-compass text-primary"></i>
          Smart exploration
        </div>
        <h5 class="fw-semibold">Search, filters, and live map discovery</h5>
        <p class="muted-copy mb-0">Move from broad inspiration to precise destination selection with category-based browsing and geo hints.</p>
      </article>

      <article class="feature-card">
        <div class="owner-badge mb-3">
          <i class="bi bi-rocket-takeoff text-success"></i>
          Host-ready platform
        </div>
        <h5 class="fw-semibold">Launch and manage listings smoothly</h5>
        <p class="muted-copy mb-0">Owners can add, update, and control properties using a clean publishing flow built on secure authentication.</p>
      </article>
    </div>
  </section>

  <section>
    <div class="cta-shell hero-card">
      <div class="section-heading mb-0">
        <div>
          <span class="mini-label">Ready to begin</span>
          <h2 class="headline-gradient">Start exploring the next wave of travel stays.</h2>
        </div>
        <div class="d-flex flex-wrap gap-3">
          <a href="/listings" class="btn btn-light">Browse now</a>
          <a href="/register" class="btn btn-outline-secondary">Create account</a>
        </div>
      </div>
    </div>
  </section>
</section>
